@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="branding">
    <div class="logo-circle"><img src="~/img/logo_transparent_clear_70_70.png" alt="heart" style="height:40px; width:40px;" /></div>
    <h1>Likes And Swipes</h1>
    <p>Let's create your profile</p>
</div>
<form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
    <div class="card">

        <!-- Progress -->
        <div class="progress">
            <div class="progress-bar" data-step="1"></div>
            <div class="progress-bar" data-step="2"></div>
            <div class="progress-bar" data-step="3"></div>
            <div class="progress-bar"></div>
            <div class="progress-bar"></div>
            <div class="progress-bar"></div>
            <div class="progress-bar"></div>
        </div>

        <span class="step-text">
            Step <span id="currentStep">1</span> of 7
        </span>

        <!-- STEP 1 -->
        <div class="form-step active" data-step="1">
            <h2>What's your name?</h2>
            <input type="text" asp-for="Input.Name" id="nameInput" placeholder="Enter your first name">
            <button type="button" class="btn-primary next-btn">Continue</button>
        </div>

        <!-- STEP 2 -->
        <div class="form-step" data-step="2">
            <h2>What's your gender?</h2>
            <div class="gender-options" id="sexOptions">
                <label class="gender-option">
                    <input type="radio" asp-for="Input.Sex" value="false">
                    <span>Man</span>
                </label>
                <label class="gender-option">
                    <input type="radio" asp-for="Input.Sex" value="true">
                    <span>Woman</span>
                </label>
            </div>
            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button type="button" class="btn-primary next-btn">Continue</button>
            </div>
        </div>

        <!-- STEP 3 -->
        <div class="form-step" data-step="3">
            <h2>Who do you prefer to meet:</h2>

            <div class="preference-group">
                <h3>Romantic:</h3>
                <label class="preference-option">
                    <input type="checkbox" asp-for="Input.RomanticMen">
                    <span>Men</span>
                </label>
                <label class="preference-option">
                    <input type="checkbox" asp-for="Input.RomanticWomen">
                    <span>Women</span>
                </label>
            </div>

            <div class="preference-group">
                <h3>Friendship:</h3>
                <label class="preference-option">
                    <input type="checkbox" asp-for="Input.FriendshipMen">
                    <span>Men</span>
                </label>
                <label class="preference-option">
                    <input type="checkbox" asp-for="Input.FriendshipWomen">
                    <span>Women</span>
                </label>
            </div>

            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button type="button" class="btn-primary next-btn">Continue</button>
            </div>
        </div>

        <!-- STEP 4 -->
        <div class="form-step" data-step="4">
            <h2>How old are you?</h2>
            <input type="number" asp-for="Input.Age" id="ageInput" placeholder="Enter your age" min="18">
            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button type="button" class="btn-primary next-btn">Continue</button>
            </div>
        </div>

        <!-- STEP 5 -->
        <div class="form-step" data-step="5">
            <h2>Add your photos</h2>
            <p class="sub-text">Add at least 2 photos to continue</p>

            <div class="photo-grid">
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                    <span>+</span>
                </label>
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                </label>
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                </label>
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                </label>
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                </label>
                <label class="photo-box">
                    <input type="file" accept="image/*" class="photo-input">
                </label>
            </div>

            <p id="photoCount">0/6 photos added</p>

            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button type="button" class="btn-primary next-btn">Continue</button>
            </div>
        </div>

        <!-- STEP 6 -->
        <div class="form-step" data-step="6">
            <h2>Select interests</h2>
            <div class="interests">
                <button type="button" class="interest">Travel</button>
                <button type="button" class="interest">Photography</button>
                <button type="button" class="interest">Hiking</button>
                <button type="button" class="interest">Coffee</button>
                <button type="button" class="interest">Cooking</button>
                <button type="button" class="interest">Music</button>
                <button type="button" class="interest">Art</button>
                <button type="button" class="interest">Wine</button>
                <button type="button" class="interest">Yoga</button>
                <button type="button" class="interest">Fitness</button>
                <button type="button" class="interest">Reading</button>
                <button type="button" class="interest">Movies</button>
                <button type="button" class="interest">Rock climbing</button>
                <button type="button" class="interest">Technology</button>
                <button type="button" class="interest">Gaming</button>
            </div>
            <p id="interestCount">0/5 selected</p>
            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button type="button" class="btn-primary next-btn">Next</button>
            </div>
        </div>

        <!-- STEP 7 -->
        <div class="form-step" data-step="7">
            <h2>Create account</h2>
            <input type="text" asp-for="Input.Email" id="email" placeholder="Email or phone" style="font-size: 20px;" />
            <input type="password" asp-for="Input.Password" id="password" placeholder="Password" style="font-size: 20px;" />
            <input type="password" asp-for="Input.ConfirmPassword" id="confirmPassword" placeholder="Confirm password" style="font-size: 20px;" />
            <div class="button-row">
                <button type="button" class="btn-secondary back-btn">Back</button>
                <button class="btn-primary" id="registerBtn" type="submit">Register</button>
            </div>
        </div>

    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
