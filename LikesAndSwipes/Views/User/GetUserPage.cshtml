@model LikesAndSwipes.Models.UserProfilePhotosViewModel
@{
    ViewData["Title"] = "Profile";
}

<section class="user-profile-page">
    <div class="user-profile-header">
        <h1>Мои фотографии</h1>
        <a asp-area="Identity" asp-page="/Account/Manage/Index">Settings</a>
    </div>

    @if (Model.IsCurrentUserProfile)
    {
        <form asp-controller="User" asp-action="AddPhoto" method="post" enctype="multipart/form-data" class="user-photo-upload-form">
            @Html.AntiForgeryToken()
            <input type="file" name="photo" accept="image/*" class="form-control user-photo-upload-input" required />
            <button type="submit" class="btn btn-primary">Добавить фото</button>
        </form>

        @if (TempData["PhotoUploadSuccess"] is string successMessage)
        {
            <p class="user-photo-upload-success">@successMessage</p>
        }

        @if (TempData["PhotoUploadError"] is string errorMessage)
        {
            <p class="user-photo-upload-error">@errorMessage</p>
        }
    }

    @if (Model.Photos.Count == 0)
    {
        <p class="user-profile-empty">Фотографии пока не загружены.</p>
    }
    else
    {
        <div class="user-photo-grid">
            @foreach (var photo in Model.Photos)
            {
                <div class="user-photo-grid-item">
                    <img src="/api/Minio/download/@photo.ObjectName" alt="User photo" loading="lazy" />
                </div>
            }
        </div>
    }
</section>
